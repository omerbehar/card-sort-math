require "base64"
require "spaceship"

# CardSortMath — TestFlight tester management.
#
# Authenticates with the App Store Connect API key (the same secrets
# mobile-build.yml uses): ASC_KEY_ID, ASC_ISSUER_ID, ASC_API_KEY_BASE64
# (base64-encoded .p8). No Apple-ID password / 2FA needed.
#
# Internal-tester reality (Apple rule): a TestFlight *internal* tester must be a
# member of your App Store Connect "Users and Access" team, and you need at least
# one *internal* Beta Group in TestFlight. This lane assigns the tester to that
# internal group; it cannot turn an arbitrary external email into a team user —
# do that once in App Store Connect → Users and Access. fastlane's `pilot` action
# can't reliably assign internal groups, so this uses Spaceship ConnectAPI directly
# (the documented workaround).
#
# See docs/ios-build.md → "Adding TestFlight testers".

default_platform(:ios)

DEFAULT_APP_IDENTIFIER = "Com.omerbehar.cardsortmath".freeze

platform :ios do
  # Adds an internal TestFlight tester and assigns them to the internal Beta Group.
  #
  #   fastlane ios add_internal_tester
  #   fastlane ios add_internal_tester email:someone@example.com first_name:Jane last_name:Doe
  #
  # Defaults to itamarb2010@gmail.com (the originally requested tester).
  desc "Add an internal TestFlight tester (default: itamarb2010@gmail.com)"
  lane :add_internal_tester do |options|
    email = options[:email] || "itamarb2010@gmail.com"
    first_name = options[:first_name] || "Itamar"
    last_name = options[:last_name] || "B"
    app_identifier = options[:app_identifier] ||
      ENV["APP_IDENTIFIER"] || DEFAULT_APP_IDENTIFIER

    _authenticate!

    app = Spaceship::ConnectAPI::App.find(app_identifier)
    UI.user_error!("App '#{app_identifier}' not found for this API key.") if app.nil?

    internal_group = app.get_beta_groups.find(&:is_internal_group)
    UI.user_error!(
      "No internal Beta Group found. Create one in App Store Connect → " \
      "TestFlight → Internal Testing, then re-run."
    ) if internal_group.nil?

    begin
      Spaceship::ConnectAPI::BetaTester.create_beta_tester(
        beta_group_id: internal_group.id,
        email: email,
        first_name: first_name,
        last_name: last_name
      )
      UI.success("Added #{email} to internal group '#{internal_group.name}'.")
    rescue => e
      UI.error("Could not add #{email}: #{e.message}")
      UI.important(
        "For INTERNAL testing the email must already be an App Store Connect " \
        "team member (Users and Access). Invite them there first, then re-run."
      )
      raise
    end
  end

  # Builds an App Store Connect API token from the CI secrets and wires it into
  # Spaceship for the duration of the lane.
  private_lane :_authenticate! do
    %w[ASC_KEY_ID ASC_ISSUER_ID ASC_API_KEY_BASE64].each do |var|
      UI.user_error!("Missing env var #{var} (App Store Connect API key).") if ENV[var].to_s.empty?
    end
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key: Base64.decode64(ENV.fetch("ASC_API_KEY_BASE64"))
    )
    Spaceship::ConnectAPI.token = token
  end
end
